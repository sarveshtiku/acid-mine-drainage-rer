# Copy to .env and fill in ( .env is gitignored; never commit keys )

# ArcGIS login (required for run_all.py; no arcpy needed)
# If you're in an organization, use your org URL, e.g. https://YOURORG.maps.arcgis.com
ARCGIS_URL=https://www.arcgis.com
ARCGIS_USERNAME=
ARCGIS_PASSWORD=

# If password contains # or ! use quotes: ARCGIS_PASSWORD="YourPass!@#$"

# USGS Water Data API key – optional; enables higher rate limits
USGS_API_KEY=

# Optional: ArcGIS profile name (default "home") used only if ARCGIS_USERNAME/PASSWORD not set
# ARCGIS_PROFILE=home
